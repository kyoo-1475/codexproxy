---
---
<section id="providers" class="py-16 md:py-20 px-4 reveal-on-scroll">
  <div class="max-w-[1180px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-12 max-w-2xl mx-auto reveal-on-scroll">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 mb-4">Supported Providers</h2>
      <p class="text-[17px] text-slate-500 leading-relaxed">
        Works with local and remote providers. All speak OpenAI-compatible APIs. Codex Proxy can route to one or many.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      
      <!-- Card 1: Ollama -->
      <a href="https://ollama.com/" target="_blank" rel="noopener noreferrer" class="card p-4 flex flex-row items-center gap-4 text-left hover:border-slate-350 h-[100px] rounded-[14px] stagger-item group" data-tilt-card>
        <div class="w-11 h-11 rounded-[10px] bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0 overflow-hidden">
          <img src={`${import.meta.env.BASE_URL}logos/ollama.svg`} class="max-w-[28px] max-h-[28px] object-contain group-hover:scale-110 transition-transform" alt="Ollama logo" />
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-slate-900 leading-tight group-hover:-translate-y-[1px] transition-transform">Ollama</div>
          <div class="text-[13px] text-slate-500 mt-0.5 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">Run models locally.</div>
        </div>
        <div class="opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-x-2 group-hover:translate-x-0 text-blue-600 shrink-0 hidden sm:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Card 2: LM Studio -->
      <a href="https://lmstudio.ai/" target="_blank" rel="noopener noreferrer" class="card p-4 flex flex-row items-center gap-4 text-left hover:border-slate-350 h-[100px] rounded-[14px] stagger-item group" data-tilt-card>
        <div class="w-11 h-11 rounded-[10px] bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0 overflow-hidden">
          <img src={`${import.meta.env.BASE_URL}logos/lmstudio.svg`} class="max-w-[28px] max-h-[28px] object-contain group-hover:scale-110 transition-transform" alt="LM Studio logo" />
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-slate-900 leading-tight group-hover:-translate-y-[1px] transition-transform">LM Studio</div>
          <div class="text-[13px] text-slate-500 mt-0.5 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">Local inference made simple.</div>
        </div>
        <div class="opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-x-2 group-hover:translate-x-0 text-indigo-600 shrink-0 hidden sm:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Card 3: vLLM -->
      <a href="https://vllm.ai/" target="_blank" rel="noopener noreferrer" class="card p-4 flex flex-row items-center gap-4 text-left hover:border-slate-350 h-[100px] rounded-[14px] stagger-item group" data-tilt-card>
        <div class="w-11 h-11 rounded-[10px] bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0 overflow-hidden">
          <img src={`${import.meta.env.BASE_URL}logos/vllm.svg`} class="max-w-[28px] max-h-[28px] object-contain group-hover:scale-110 transition-transform" alt="vLLM logo" />
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-slate-900 leading-tight group-hover:-translate-y-[1px] transition-transform">vLLM</div>
          <div class="text-[13px] text-slate-500 mt-0.5 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">High-throughput engine.</div>
        </div>
        <div class="opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-x-2 group-hover:translate-x-0 text-blue-600 shrink-0 hidden sm:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Card 4: SGLang -->
      <a href="https://docs.sglang.ai/" target="_blank" rel="noopener noreferrer" class="card p-4 flex flex-row items-center gap-4 text-left hover:border-slate-350 h-[100px] rounded-[14px] stagger-item group" data-tilt-card>
        <div class="w-11 h-11 rounded-[10px] bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500 group-hover:scale-110 transition-transform">
            <polyline points="13 17 18 12 13 7"></polyline>
            <polyline points="6 17 11 12 6 7"></polyline>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-slate-900 leading-tight group-hover:-translate-y-[1px] transition-transform">SGLang</div>
          <div class="text-[13px] text-slate-500 mt-0.5 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">Memory-efficient serving.</div>
        </div>
        <div class="opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-x-2 group-hover:translate-x-0 text-cyan-500 shrink-0 hidden sm:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Card 5: NVIDIA Build -->
      <a href="https://build.nvidia.com/" target="_blank" rel="noopener noreferrer" class="card p-4 flex flex-row items-center gap-4 text-left hover:border-slate-350 h-[100px] rounded-[14px] stagger-item group" data-tilt-card>
        <div class="w-11 h-11 rounded-[10px] bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0 overflow-hidden">
          <img src={`${import.meta.env.BASE_URL}logos/nvidia.svg`} class="max-w-[28px] max-h-[28px] object-contain group-hover:scale-110 transition-transform" alt="NVIDIA logo" />
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-slate-900 leading-tight group-hover:-translate-y-[1px] transition-transform">NVIDIA Build</div>
          <div class="text-[13px] text-slate-500 mt-0.5 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">NVIDIA-hosted inference.</div>
        </div>
        <div class="opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-x-2 group-hover:translate-x-0 text-emerald-600 shrink-0 hidden sm:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Card 6: OpenRouter -->
      <a href="https://openrouter.ai/" target="_blank" rel="noopener noreferrer" class="card p-4 flex flex-row items-center gap-4 text-left hover:border-slate-350 h-[100px] rounded-[14px] stagger-item group" data-tilt-card>
        <div class="w-11 h-11 rounded-[10px] bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0 overflow-hidden">
          <img src={`${import.meta.env.BASE_URL}logos/openrouter.svg`} class="max-w-[28px] max-h-[28px] object-contain group-hover:scale-110 transition-transform" alt="OpenRouter logo" />
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-slate-900 leading-tight group-hover:-translate-y-[1px] transition-transform">OpenRouter</div>
          <div class="text-[13px] text-slate-500 mt-0.5 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">Access hundreds of models.</div>
        </div>
        <div class="opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-x-2 group-hover:translate-x-0 text-purple-600 shrink-0 hidden sm:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Card 7: DeepSeek -->
      <a href="https://www.deepseek.com/" target="_blank" rel="noopener noreferrer" class="card p-4 flex flex-row items-center gap-4 text-left hover:border-slate-350 h-[100px] rounded-[14px] stagger-item group" data-tilt-card>
        <div class="w-11 h-11 rounded-[10px] bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0 overflow-hidden">
          <img src={`${import.meta.env.BASE_URL}logos/deepseek.svg`} class="max-w-[28px] max-h-[28px] object-contain group-hover:scale-110 transition-transform" alt="DeepSeek logo" />
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-slate-900 leading-tight group-hover:-translate-y-[1px] transition-transform">DeepSeek</div>
          <div class="text-[13px] text-slate-500 mt-0.5 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">Powerful code models.</div>
        </div>
        <div class="opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-x-2 group-hover:translate-x-0 text-blue-600 shrink-0 hidden sm:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Card 8: Any API -->
      <a href="#quick-start" class="card p-4 flex flex-row items-center gap-4 text-left border-indigo-100 bg-gradient-to-br from-white to-indigo-50/50 hover:border-indigo-300 h-[100px] rounded-[14px] stagger-item group" data-tilt-card>
        <div class="w-11 h-11 rounded-[10px] bg-indigo-50 border border-indigo-200/60 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600 group-hover:scale-110 transition-transform">
            <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
            <polyline points="2 17 12 22 22 17"></polyline>
            <polyline points="2 12 12 17 22 12"></polyline>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-indigo-900 leading-tight group-hover:-translate-y-[1px] transition-transform">Any API</div>
          <div class="text-[13px] text-slate-500 mt-0.5 leading-snug opacity-80 group-hover:opacity-100 transition-opacity">Any OpenAI-compatible API.</div>
        </div>
        <div class="opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-x-2 group-hover:translate-x-0 text-indigo-600 shrink-0 hidden sm:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

    </div>
  </div>
</section>
