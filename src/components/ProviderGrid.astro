---
---
<section id="providers" class="py-16 md:py-24 px-4">
  <div class="max-w-[1180px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 mb-4">Supported Providers</h2>
      <p class="text-[17px] text-slate-500 leading-relaxed">
        Works with local and remote providers. All speak OpenAI-compatible APIs. Codex Proxy can route to one or many.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <!-- Card 1 -->
      <div class="card p-6 flex flex-col items-start text-left hover:border-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-800 mb-4"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        <div class="font-bold text-lg text-slate-900 mb-2">Ollama</div>
        <p class="text-sm text-slate-500 leading-relaxed">Run models locally with Ollama.</p>
      </div>

      <!-- Card 2 -->
      <div class="card p-6 flex flex-col items-start text-left hover:border-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-800 mb-4"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <div class="font-bold text-lg text-slate-900 mb-2">LM Studio</div>
        <p class="text-sm text-slate-500 leading-relaxed">Local inference made simple.</p>
      </div>

      <!-- Card 3 -->
      <div class="card p-6 flex flex-col items-start text-left hover:border-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-800 mb-4"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <div class="font-bold text-lg text-slate-900 mb-2">vLLM</div>
        <p class="text-sm text-slate-500 leading-relaxed">High-throughput inference engine.</p>
      </div>

      <!-- Card 4 -->
      <div class="card p-6 flex flex-col items-start text-left hover:border-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-800 mb-4"><polygon points="13 19 22 12 13 5 13 19"/><polygon points="2 19 11 12 2 5 2 19"/></svg>
        <div class="font-bold text-lg text-slate-900 mb-2">SGLang</div>
        <p class="text-sm text-slate-500 leading-relaxed">Fast, memory-efficient serving.</p>
      </div>

      <!-- Card 5 -->
      <div class="card p-6 flex flex-col items-start text-left hover:border-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-800 mb-4"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>
        <div class="font-bold text-lg text-slate-900 mb-2">NVIDIA Build</div>
        <p class="text-sm text-slate-500 leading-relaxed">NVIDIA-hosted inference.</p>
      </div>

      <!-- Card 6 -->
      <div class="card p-6 flex flex-col items-start text-left hover:border-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-800 mb-4"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
        <div class="font-bold text-lg text-slate-900 mb-2">OpenRouter</div>
        <p class="text-sm text-slate-500 leading-relaxed">Access hundreds of models.</p>
      </div>

      <!-- Card 7 -->
      <div class="card p-6 flex flex-col items-start text-left hover:border-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-800 mb-4"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <div class="font-bold text-lg text-slate-900 mb-2">DeepSeek</div>
        <p class="text-sm text-slate-500 leading-relaxed">Powerful models by DeepSeek.</p>
      </div>

      <!-- Card 8 -->
      <div class="card p-6 flex flex-col items-start text-left border-indigo-100 bg-gradient-to-br from-white to-indigo-50/50 hover:border-indigo-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600 mb-4"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        <div class="font-bold text-lg text-indigo-700 mb-2">Any compatible API</div>
        <p class="text-sm text-slate-500 leading-relaxed">Any OpenAI-compatible endpoint.</p>
      </div>

    </div>
  </div>
</section>
