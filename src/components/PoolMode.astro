---
---
<section id="pool-mode" class="py-16 md:py-20 px-4">
  <div class="max-w-[1180px] mx-auto">
    
    <!-- Header -->
    <div class="text-center mb-8 max-w-2xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-100 text-xs font-semibold text-blue-700 mb-6 tracking-wider">
        BUILT FOR RELIABILITY
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 mb-4">Enterprise-grade Pool Mode</h2>
      <p class="text-[17px] text-slate-500 leading-relaxed">
        Pool Mode adds intelligent routing with failover, multi-key rotation, cooldowns, and curated logical profiles. Ship resilient AI workflows without managing complexity.
      </p>
    </div>

    <!-- Structured Capability Cards Grid -->
    <div class="pool-capabilities">
      <div class="pool-capability-card">
        <div class="pool-capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 11 3 3 3-3"/></svg>
        </div>
        <h3 class="pool-capability-title">Failover</h3>
        <p class="pool-capability-desc">Automatically retries another provider when one fails.</p>
      </div>
      
      <div class="pool-capability-card">
        <div class="pool-capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        </div>
        <h3 class="pool-capability-title">Multi-key rotation</h3>
        <p class="pool-capability-desc">Spread traffic across multiple keys per provider.</p>
      </div>

      <div class="pool-capability-card">
        <div class="pool-capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="pool-capability-title">Cooldowns</h3>
        <p class="pool-capability-desc">Temporarily pauses unhealthy providers after errors.</p>
      </div>

      <div class="pool-capability-card">
        <div class="pool-capability-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
        </div>
        <h3 class="pool-capability-title">Logical profiles</h3>
        <p class="pool-capability-desc">Expose codex-fast, codex-balanced, and codex-strong to Codex.</p>
      </div>
    </div>

    <!-- Main Container -->
    <div class="bg-white rounded-[20px] shadow-sm border border-slate-200/80 p-6 md:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
        
        <!-- Left Column: Profile Cards & Diagram -->
        <div class="flex flex-col gap-6">
          <div class="text-[14px] font-bold text-slate-800">Available Profiles</div>
          <!-- Profile Cards -->
          <div class="grid gap-3">
            <div class="bg-slate-50/50 rounded-[14px] p-4 flex flex-col justify-center border-l-4 border-l-cyan-500 border-y border-r border-slate-200/50 h-[88px]">
              <div class="font-bold text-slate-900 text-[15px] mb-0.5">codex-fast</div>
              <div class="text-[13px] text-slate-500">Low latency. Optimized for speed and completions.</div>
            </div>
            <div class="bg-slate-50/50 rounded-[14px] p-4 flex flex-col justify-center border-l-4 border-l-blue-500 border-y border-r border-slate-200/50 h-[88px]">
              <div class="font-bold text-slate-900 text-[15px] mb-0.5">codex-balanced</div>
              <div class="text-[13px] text-slate-500">Best overall quality, cost, and latency. Default.</div>
            </div>
            <div class="bg-slate-50/50 rounded-[14px] p-4 flex flex-col justify-center border-l-4 border-l-purple-500 border-y border-r border-slate-200/50 h-[88px]">
              <div class="font-bold text-slate-900 text-[15px] mb-0.5">codex-strong</div>
              <div class="text-[13px] text-slate-500">Max quality for complex architectural tasks.</div>
            </div>
          </div>

          <!-- Routing Diagram -->
          <div class="bg-slate-50/80 rounded-[14px] p-5 border border-slate-200/60">
            <div class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-3">Live Routing Visualization</div>
            
            <div class="flex flex-col gap-3 font-mono text-[12.5px]">
              <!-- Request -->
              <div class="flex items-center justify-between bg-white border border-slate-200/80 p-3 rounded-[12px] shadow-sm">
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse"></span>
                  <span class="font-bold text-slate-800">Request</span>
                </div>
                <div class="text-slate-400">Target: <span class="text-blue-600 font-bold">codex-balanced</span></div>
              </div>

              <!-- Arrow -->
              <div class="flex justify-center -my-1 text-slate-300">&darr;</div>

              <!-- NVIDIA (Primary) -->
              <div class="flex items-center justify-between bg-white border border-slate-200/80 p-3 rounded-[12px] shadow-sm border-l-4 border-l-emerald-500">
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                  <span class="font-bold text-slate-800">1. NVIDIA Build (Primary)</span>
                </div>
                <div class="text-slate-500">Weight: 3 &bull; <span class="text-emerald-600 font-semibold">Healthy</span></div>
              </div>

              <!-- Arrow -->
              <div class="flex justify-center -my-1 text-slate-300">&darr;</div>

              <!-- OpenRouter (Fallback / Cooldown) -->
              <div class="flex items-center justify-between bg-white border border-slate-200/80 p-3 rounded-[12px] shadow-sm border-l-4 border-l-amber-500">
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                  <span class="font-bold text-slate-800">2. OpenRouter (Fallback)</span>
                </div>
                <div class="text-slate-500">Weight: 1 &bull; <span class="text-amber-600 font-semibold">Cooldown (45s left)</span></div>
              </div>
            </div>
          </div>

        </div>

        <!-- Right Column: Code & Why -->
        <div class="flex flex-col gap-6 h-full justify-between">
          
          <!-- Code Panel -->
          <div class="terminal flex-1 min-h-[300px]">
            <div class="flex items-center px-4 py-3 bg-[#0B1526] border-b border-white/5">
              <div class="mx-auto text-xs font-medium text-slate-400 font-mono">pool.yaml</div>
            </div>
            <div class="p-5 font-mono text-[13px] leading-[1.6] text-slate-300 overflow-x-auto">
<pre><code><span class="text-purple-400">pools:</span>
  <span class="text-blue-400">codex-fast:</span>
    <span class="text-cyan-400">strategy:</span> priority
    <span class="text-cyan-400">cooldown:</span> 60
    <span class="text-cyan-400">retries:</span> 2
    <span class="text-cyan-400">providers:</span>
      - <span class="text-emerald-400">openrouter:</span> &#123; api_key: <span class="text-slate-400">{"${KEY}"}</span>, priority: 1 &#125;
      - <span class="text-emerald-400">deepseek:</span>   &#123; api_key: <span class="text-slate-400">{"${KEY}"}</span>, priority: 2 &#125;

  <span class="text-blue-400">codex-balanced:</span>
    <span class="text-cyan-400">strategy:</span> weighted
    <span class="text-cyan-400">providers:</span>
      - <span class="text-emerald-400">nvidia:</span>     &#123; api_key: <span class="text-slate-400">{"${KEY}"}</span>, weight: 3 &#125;
      - <span class="text-emerald-400">openrouter:</span> &#123; api_key: <span class="text-slate-400">{"${KEY}"}</span>, weight: 1 &#125;

  <span class="text-blue-400">codex-strong:</span>
    <span class="text-cyan-400">strategy:</span> priority
    <span class="text-cyan-400">providers:</span>
      - <span class="text-emerald-400">nvidia:</span>     &#123; best_effort: true, priority: 1 &#125;
      - <span class="text-emerald-400">openrouter:</span> &#123; api_key: <span class="text-slate-400">{"${KEY}"}</span>, priority: 2 &#125;</code></pre>
            </div>
          </div>

          <!-- Why Pool Mode -->
          <div class="pt-4 px-2">
            <h3 class="text-lg font-bold text-slate-900 mb-4">Why Pool Mode?</h3>
            <div class="grid grid-cols-2 gap-y-3 gap-x-4">
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="text-[14px] text-slate-700">Higher uptime (failover)</span>
              </div>
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="text-[14px] text-slate-700">Smarter cost routing</span>
              </div>
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="text-[14px] text-slate-700">Multi-key rotation</span>
              </div>
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="text-[14px] text-slate-700">Curated profiles</span>
              </div>
            </div>
          </div>

        </div>

      </div>
    </div>
  </div>
</section>

<style>
.pool-capabilities {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  margin: 36px auto 28px;
}

.pool-capability-card {
  border: 1px solid rgba(226, 232, 240, 0.95);
  background: rgba(255, 255, 255, 0.78);
  border-radius: 14px;
  padding: 16px;
  transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.pool-capability-card:hover {
  transform: translateY(-2px);
  border-color: rgba(79, 70, 229, 0.34);
  box-shadow: 0 14px 34px rgba(37, 99, 235, 0.08);
}

.pool-capability-icon {
  width: 30px;
  height: 30px;
  border-radius: 10px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, rgba(59,130,246,.12), rgba(124,58,237,.12));
  color: #4f46e5;
}

.pool-capability-title {
  margin-top: 12px;
  font-size: 14px;
  font-weight: 700;
  color: #0f172a;
}

.pool-capability-desc {
  margin-top: 4px;
  font-size: 12.5px;
  line-height: 1.45;
  color: #64748b;
}

@media (max-width: 900px) {
  .pool-capabilities {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 560px) {
  .pool-capabilities {
    grid-template-columns: 1fr;
  }
}
</style>
