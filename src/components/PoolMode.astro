---
---
<section id="pool-mode" class="py-16 md:py-24 px-4 bg-slate-50/50 border-y border-slate-200/50">
  <div class="max-w-[1180px] mx-auto">
    
    <!-- Header -->
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-100 text-xs font-semibold text-blue-700 mb-6 tracking-wider">
        BUILT FOR RELIABILITY
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 mb-6">Enterprise-grade Pool Mode</h2>
      <p class="text-[17px] text-slate-500 leading-relaxed">
        Pool Mode adds intelligent routing with failover, multi-key rotation, cooldowns, and curated logical profiles. Ship resilient AI workflows without managing complexity.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      
      <!-- Left Column: Concepts & Diagram -->
      <div class="flex flex-col gap-8">
        
        <!-- Capabilities -->
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-white border border-slate-200 rounded-full text-sm font-medium text-slate-700 shadow-sm">Failover & Retries</span>
          <span class="px-3 py-1 bg-white border border-slate-200 rounded-full text-sm font-medium text-slate-700 shadow-sm">Multi-key Rotation</span>
          <span class="px-3 py-1 bg-white border border-slate-200 rounded-full text-sm font-medium text-slate-700 shadow-sm">Cooldowns</span>
          <span class="px-3 py-1 bg-white border border-slate-200 rounded-full text-sm font-medium text-slate-700 shadow-sm">Logical Profiles</span>
        </div>

        <!-- Profile Cards -->
        <div class="grid gap-4">
          <div class="bg-white rounded-xl p-5 flex flex-col border-l-4 border-l-cyan-500 shadow-sm border border-slate-100">
            <div class="font-bold text-slate-900 text-lg mb-1">codex-fast</div>
            <div class="text-xs font-semibold text-cyan-600 mb-2">Low latency</div>
            <div class="text-sm text-slate-500">Optimized for speed and responsiveness.</div>
          </div>
          <div class="bg-white rounded-xl p-5 flex flex-col border-l-4 border-l-blue-500 shadow-sm border border-slate-100">
            <div class="font-bold text-slate-900 text-lg mb-1">codex-balanced</div>
            <div class="text-xs font-semibold text-blue-600 mb-2">Best overall</div>
            <div class="text-sm text-slate-500">Balanced quality, cost, and latency.</div>
          </div>
          <div class="bg-white rounded-xl p-5 flex flex-col border-l-4 border-l-purple-500 shadow-sm border border-slate-100">
            <div class="font-bold text-slate-900 text-lg mb-1">codex-strong</div>
            <div class="text-xs font-semibold text-purple-600 mb-2">Highest quality</div>
            <div class="text-sm text-slate-500">Max quality for complex tasks.</div>
          </div>
        </div>

        <!-- Routing Diagram -->
        <div class="bg-white rounded-xl p-6 border border-slate-200/60 shadow-sm">
          <div class="font-mono text-sm">
            <div class="text-slate-800 font-bold mb-2">Request &rarr; Pool (codex-balanced)</div>
            <div class="pl-4 border-l-2 border-slate-300 ml-2 mb-4 space-y-1">
              <div class="text-slate-600">1. Try NVIDIA (weight 3)</div>
              <div class="text-slate-600">2. Try OpenRouter (weight 1)</div>
              <div class="text-slate-600">3. Failover on error</div>
            </div>
            <div class="text-slate-800 font-bold mb-2">Provider states:</div>
            <div class="pl-4 space-y-1">
              <div class="text-emerald-600">NVIDIA &mdash; Healthy</div>
              <div class="text-blue-600">OpenRouter &mdash; Weight: 1</div>
              <div class="text-amber-600">OpenRouter &mdash; Cooldown</div>
            </div>
          </div>
        </div>

      </div>

      <!-- Right Column: Code & Why -->
      <div class="flex flex-col gap-8">
        
        <!-- Code Panel -->
        <div class="terminal flex flex-col h-full">
          <div class="flex items-center px-4 py-3 bg-[#0B1526] border-b border-white/5">
            <div class="mx-auto text-xs font-medium text-slate-400 font-mono">pool.yaml</div>
          </div>
          <div class="p-6 font-mono text-[13px] leading-relaxed text-slate-300 overflow-x-auto">
<pre><code><span class="text-purple-400">pools:</span>
  <span class="text-blue-400">codex-fast:</span>
    <span class="text-cyan-400">strategy:</span> priority
    <span class="text-cyan-400">cooldown:</span> 60
    <span class="text-cyan-400">retries:</span> 2
    <span class="text-cyan-400">providers:</span>
      - <span class="text-emerald-400">openrouter:</span> &#123; api_key: <span class="text-slate-400">{"${OPENROUTER_KEY}"}</span>, priority: 1 &#125;
      - <span class="text-emerald-400">deepseek:</span>   &#123; api_key: <span class="text-slate-400">{"${DEEPSEEK_KEY}"}</span>, priority: 2 &#125;

  <span class="text-blue-400">codex-balanced:</span>
    <span class="text-cyan-400">strategy:</span> weighted
    <span class="text-cyan-400">providers:</span>
      - <span class="text-emerald-400">nvidia:</span>     &#123; api_key: <span class="text-slate-400">{"${NVIDIA_KEY}"}</span>, weight: 3 &#125;
      - <span class="text-emerald-400">openrouter:</span> &#123; api_key: <span class="text-slate-400">{"${OPENROUTER_KEY}"}</span>, weight: 1 &#125;

  <span class="text-blue-400">codex-strong:</span>
    <span class="text-cyan-400">strategy:</span> priority
    <span class="text-cyan-400">providers:</span>
      - <span class="text-emerald-400">nvidia:</span>     &#123; best_effort: true, priority: 1 &#125;
      - <span class="text-emerald-400">openrouter:</span> &#123; api_key: <span class="text-slate-400">{"${OPENROUTER_KEY}"}</span>, priority: 2 &#125;</code></pre>
          </div>
        </div>

        <!-- Why Pool Mode -->
        <div class="bg-white rounded-xl p-8 border border-slate-200/60 shadow-sm">
          <h3 class="text-xl font-bold text-slate-900 mb-6">Why Pool Mode?</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-slate-700">Higher uptime with automatic failover</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-slate-700">Smarter cost & best latency/money</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-slate-700">Multiple keys per provider</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-slate-700">Curated profiles for every use case</span>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </div>
</section>
