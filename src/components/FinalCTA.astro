<section class="py-20 px-4">
  <div class="max-w-[1180px] mx-auto">
    <div class="relative overflow-hidden py-16 px-6 md:px-12 flex flex-col items-center text-center rounded-[24px] bg-slate-900 shadow-2xl border border-slate-800">
      <!-- Background pattern -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-900/40 via-slate-900 to-purple-900/40 z-0"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80%] h-[80%] bg-blue-500/20 blur-[100px] rounded-full pointer-events-none z-0"></div>
      
      <!-- Content -->
      <div class="relative z-10 max-w-2xl mx-auto">
        <div class="w-16 h-16 mx-auto mb-8 bg-[#0F172A] rounded-2xl shadow-sm border border-slate-700 flex items-center justify-center text-blue-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none" />
            <path d="M21 7.5V16.5L13 21H11L3 16.5V7.5L11 3H13L21 7.5Z" />
            <path d="M12 3v6" />
            <path d="M4 8l5 3" />
            <path d="M20 8l-5 3" />
          </svg>
        </div>
        
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6">Build the future, your way.</h2>
        <p class="text-lg text-slate-400 mb-10">One proxy. Any model. Infinite possibilities.</p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#quick-start" class="btn-primary w-full sm:w-auto px-8 py-3.5 font-medium text-center">
            Get Started Now &rarr;
          </a>
          <a href="https://github.com/kyoo-147/codex_proxy_for_all_models" target="_blank" rel="noopener noreferrer" class="btn-secondary w-full sm:w-auto px-8 py-3.5 font-medium text-center !bg-slate-800 !text-white !border-slate-700 hover:!bg-slate-700 hover:!border-slate-600">
            Star on GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
