---
---
<section id="quick-start" class="py-16 md:py-24 px-4 bg-slate-900 border-y border-slate-800 text-slate-300">
  <div class="max-w-[800px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-4">Quick Start</h2>
      <p class="text-slate-400">Get up and running in less than 60 seconds.</p>
    </div>

    <!-- Tabs Container -->
    <div class="rounded-xl overflow-hidden bg-[#0F172A] border border-slate-800 shadow-2xl">
      <!-- Tabs Nav -->
      <div class="flex items-center bg-[#0B1220] border-b border-slate-800 px-2 pt-2">
        <div class="px-5 py-2.5 bg-[#0F172A] rounded-t-lg font-medium text-blue-400 text-sm border-t border-x border-slate-700/50 -mb-[1px]">macOS / Linux</div>
        <div class="px-5 py-2.5 text-slate-500 font-medium text-sm">Windows PowerShell</div>
        <div class="px-5 py-2.5 text-slate-500 font-medium text-sm">Docker</div>
      </div>

      <!-- Tab Content -->
      <div class="p-6 md:p-8 font-mono text-[13px] leading-relaxed">
        
        <div class="mb-6">
          <div class="text-slate-500 mb-2 font-sans text-xs uppercase tracking-wider font-semibold">1. Clone &amp; Enter</div>
          <div class="flex items-start gap-3">
            <span class="text-emerald-400 shrink-0">$</span>
            <span class="text-slate-300">git clone https://github.com/kyoo-147/codex_proxy_for_all_models.git<br/>cd codex_proxy_for_all_models</span>
          </div>
        </div>

        <div class="mb-6">
          <div class="text-slate-500 mb-2 font-sans text-xs uppercase tracking-wider font-semibold">2. Configure</div>
          <div class="flex items-start gap-3">
            <span class="text-emerald-400 shrink-0">$</span>
            <span class="text-slate-300"><span class="text-purple-400">export</span> CODEX_PROXY_UPSTREAM_BASE_URL=<span class="text-cyan-400">http://127.0.0.1:11434</span><br/><span class="text-purple-400">export</span> CODEX_PROXY_UPSTREAM_MODEL=<span class="text-cyan-400">llama3.1:70b</span></span>
          </div>
        </div>

        <div class="mb-8">
          <div class="text-slate-500 mb-2 font-sans text-xs uppercase tracking-wider font-semibold">3. Run Proxy</div>
          <div class="flex items-start gap-3">
            <span class="text-emerald-400 shrink-0">$</span>
            <span class="text-slate-300"><span class="text-indigo-400">python</span> -m codex_proxy_for_all_models</span>
          </div>
        </div>

        <div class="p-5 rounded-lg bg-[#0B1220] border border-white/5">
          <div class="flex justify-between items-center mb-3">
            <div class="text-slate-400 font-sans text-xs font-semibold">Codex config.toml</div>
            <button class="text-slate-500 hover:text-white transition-colors" aria-label="Copy code">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
          </div>
<pre class="m-0 text-slate-300"><code><span class="text-purple-400">[proxy]</span>
<span class="text-cyan-400">provider</span> = <span class="text-emerald-400">"codex-proxy"</span>
<span class="text-cyan-400">base_url</span> = <span class="text-emerald-400">"http://127.0.0.1:8787"</span>

<span class="text-purple-400">[models]</span>
<span class="text-cyan-400">default</span> = <span class="text-emerald-400">"codex-balanced"</span></code></pre>
        </div>

      </div>
    </div>
  </div>
</section>
