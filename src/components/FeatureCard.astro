---
const { title, description, icon } = Astro.props;
---
<div class="premium-card p-6 flex flex-col gap-4">
  <div class="w-10 h-10 rounded-full bg-slate-50 border border-slate-100 flex items-center justify-center text-blue-600 shadow-sm">
    <Fragment set:html={icon} />
  </div>
  <div>
    <h3 class="text-slate-900 font-semibold text-[17px] mb-1.5">{title}</h3>
    <p class="text-slate-500 text-sm leading-relaxed">{description}</p>
  </div>
</div>
