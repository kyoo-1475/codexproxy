---
const values = [
  {
    title: "Near-zero overhead",
    description: "Minimal latency. Maximum throughput.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>`
  },
  {
    title: "Zero dependencies",
    description: "Pure Python. Easy to deploy anywhere.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>`
  },
  {
    title: "Open & Secure",
    description: "Open source and built with transparency.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-600"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`
  },
  {
    title: "OpenAI-compatible",
    description: "Works with any compatible backend.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-600"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`
  }
];
---
<section class="py-12 px-4">
  <div class="max-w-[1180px] mx-auto">
    <div class="bg-white border border-blue-100 rounded-3xl shadow-sm p-2 flex flex-col lg:flex-row divide-y lg:divide-y-0 lg:divide-x divide-slate-100">
      {values.map((v) => (
        <div class="flex-1 p-6 lg:p-8 flex flex-col items-center lg:items-start text-center lg:text-left gap-4 hover:bg-slate-50/50 transition-colors first:rounded-t-2xl lg:first:rounded-l-2xl lg:first:rounded-tr-none last:rounded-b-2xl lg:last:rounded-r-2xl lg:last:rounded-bl-none">
          <div class="w-10 h-10 rounded-full bg-blue-50/50 flex items-center justify-center shrink-0">
            <Fragment set:html={v.icon} />
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 text-[15px] mb-1">{v.title}</h3>
            <p class="text-slate-500 text-sm">{v.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
