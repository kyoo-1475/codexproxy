---
import FeatureCard from './FeatureCard.astro';

const features = [
  {
    title: "Near-zero overhead",
    description: "Blazing fast proxy with minimal latency.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`
  },
  {
    title: "Local & Remote",
    description: "Run local Ollama models or remote APIs effortlessly.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>`
  },
  {
    title: "Native Translation",
    description: "Responses API compatible out of the box.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`
  },
  {
    title: "Pool Mode",
    description: "Curated fallback profiles for daily work.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg>`
  }
];
---
<section class="py-16 md:py-24 px-4">
  <div class="max-w-[1180px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      
      <!-- Left Cards (Desktop) -->
      <div class="hidden lg:flex lg:col-span-3 flex-col gap-6">
        <FeatureCard {...features[0]} />
        <FeatureCard {...features[1]} />
      </div>

      <!-- Terminal -->
      <div class="col-span-1 lg:col-span-6 order-first lg:order-none">
        <div class="terminal-mockup">
          <!-- Top Bar -->
          <div class="flex items-center px-4 py-3 bg-[#0B1526] border-b border-white/5">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-rose-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-amber-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-emerald-500/80"></div>
            </div>
            <div class="mx-auto text-xs font-medium text-slate-400 font-mono tracking-wide">codex-proxy</div>
          </div>
          <!-- Content -->
          <div class="p-5 font-mono text-[13px] leading-relaxed text-slate-300">
            <div class="flex items-start gap-3 mb-1">
              <span class="text-blue-500 font-bold shrink-0">➜</span>
              <span><span class="text-purple-400">export</span> CODEX_PROXY_UPSTREAM_BASE_URL=<span class="text-cyan-400">"http://127.0.0.1:11434/v1"</span></span>
            </div>
            <div class="flex items-start gap-3 mb-1">
              <span class="text-blue-500 font-bold shrink-0">➜</span>
              <span><span class="text-purple-400">export</span> CODEX_PROXY_UPSTREAM_MODEL=<span class="text-cyan-400">"qwen2.5-coder:7b"</span></span>
            </div>
            <div class="flex items-start gap-3 mb-6">
              <span class="text-blue-500 font-bold shrink-0">➜</span>
              <span><span class="text-indigo-400">python</span> -m codex_proxy_for_all_models</span>
            </div>
            
            <div class="text-slate-400">INFO: Starting Codex Proxy...</div>
            <div class="text-slate-400">INFO: Mode: single_upstream</div>
            <div class="text-slate-400 mb-6">INFO: Listening on <a href="#" class="text-blue-400 hover:underline">http://127.0.0.1:8787</a></div>

            <div class="text-slate-400">INFO: 127.0.0.1 - "GET /models HTTP/1.1" <span class="text-emerald-400">200 OK</span></div>
            <div class="text-slate-400">INFO: 127.0.0.1 - "POST /responses HTTP/1.1" <span class="text-emerald-400">200 OK</span></div>
          </div>
        </div>
      </div>

      <!-- Right Cards (Desktop) -->
      <div class="hidden lg:flex lg:col-span-3 flex-col gap-6">
        <FeatureCard {...features[2]} />
        <FeatureCard {...features[3]} />
      </div>

      <!-- Mobile/Tablet Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:hidden w-full">
        {features.map(f => <FeatureCard {...f} />)}
      </div>

    </div>
  </div>
</section>
