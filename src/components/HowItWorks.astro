---
---
<section class="py-16 md:py-20 px-4 bg-gradient-to-b from-transparent to-slate-50/50">
  <div class="max-w-[1180px] mx-auto text-center">
    
    <!-- Title -->
    <h2 class="text-xl md:text-2xl font-bold tracking-tight text-slate-900 mb-10">
      How it works
    </h2>

    <!-- Flow Rail -->
    <div class="flex flex-col md:flex-row items-stretch justify-center gap-2 md:gap-4 relative z-10 max-w-[1000px] mx-auto">
      
      <!-- Step 1 -->
      <div class="bg-white border border-slate-200/80 rounded-xl p-5 flex flex-col items-center flex-1 min-w-0 shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-slate-50 flex items-center justify-center text-slate-600 mb-3 border border-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </div>
        <div class="font-bold text-slate-900 text-sm mb-0.5 truncate w-full text-center">Codex IDE / CLI</div>
        <div class="text-[11px] text-slate-500 truncate w-full text-center">Your local tools</div>
      </div>

      <!-- Arrow -->
      <div class="hidden md:flex items-center justify-center text-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
      <div class="flex md:hidden items-center justify-center text-slate-300 rotate-90 my-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <!-- Step 2 -->
      <div class="bg-white border border-slate-200/80 rounded-xl p-5 flex flex-col items-center flex-1 min-w-0 shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-slate-50 flex items-center justify-center text-slate-600 mb-3 border border-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
        </div>
        <div class="font-bold text-slate-900 text-sm mb-0.5 truncate w-full text-center">Responses API</div>
        <div class="text-[11px] text-slate-500 truncate w-full text-center">Standard format</div>
      </div>

      <!-- Arrow -->
      <div class="hidden md:flex items-center justify-center text-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
      <div class="flex md:hidden items-center justify-center text-slate-300 rotate-90 my-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <!-- Step 3 (Highlighted) -->
      <div class="bg-indigo-50/30 border-2 border-indigo-500/80 rounded-xl p-5 flex flex-col items-center flex-1 min-w-0 shadow-[0_8px_24px_rgba(99,102,241,0.12)] relative">
        <div class="w-10 h-10 rounded-lg bg-indigo-600 flex items-center justify-center text-white mb-3 shadow-md">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none" />
            <path d="M21 7.5V16.5L13 21H11L3 16.5V7.5L11 3H13L21 7.5Z" />
            <path d="M12 3v6" />
            <path d="M4 8l5 3" />
            <path d="M20 8l-5 3" />
          </svg>
        </div>
        <div class="font-bold text-slate-900 text-sm mb-0.5 truncate w-full text-center">Codex Proxy</div>
        <div class="text-[11px] text-indigo-700 font-medium truncate w-full text-center">Route & manage</div>
      </div>

      <!-- Arrow -->
      <div class="hidden md:flex items-center justify-center text-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
      <div class="flex md:hidden items-center justify-center text-slate-300 rotate-90 my-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <!-- Step 4 -->
      <div class="bg-white border border-slate-200/80 rounded-xl p-5 flex flex-col items-center flex-1 min-w-0 shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-slate-50 flex items-center justify-center text-slate-600 mb-3 border border-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 14v1"/><path d="M9 19v2"/><path d="M9 3v2"/><path d="M9 9v1"/><path d="M15 14v1"/><path d="M15 19v2"/><path d="M15 3v2"/><path d="M15 9v1"/></svg>
        </div>
        <div class="font-bold text-slate-900 text-sm mb-0.5 truncate w-full text-center">Upstreams</div>
        <div class="text-[11px] text-slate-500 truncate w-full text-center">Chat / Completions</div>
      </div>

    </div>
  </div>
</section>
