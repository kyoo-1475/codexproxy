---
---
<section class="py-16 md:py-24 px-4 bg-gradient-to-b from-transparent to-slate-50/50">
  <div class="max-w-[1180px] mx-auto text-center">
    
    <!-- Title -->
    <h2 class="text-xl md:text-2xl font-bold tracking-tight text-slate-900 mb-12">
      How it works
    </h2>

    <!-- Flow -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-6 relative z-10">
      
      <!-- Step 1 -->
      <div class="card p-6 w-full md:w-56 flex flex-col items-center">
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-700 mb-4 border border-slate-200 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </div>
        <div class="font-bold text-slate-900 text-sm mb-1">Codex IDE / CLI</div>
        <div class="text-xs text-slate-500">Your tools</div>
      </div>

      <!-- Arrow -->
      <div class="hidden md:block text-blue-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
      <div class="block md:hidden text-blue-300 rotate-90 my-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <!-- Step 2 -->
      <div class="card p-6 w-full md:w-56 flex flex-col items-center">
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-700 mb-4 border border-slate-200 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
        </div>
        <div class="font-bold text-slate-900 text-sm mb-1">Responses API</div>
        <div class="text-xs text-slate-500">OpenAI-compatible</div>
      </div>

      <!-- Arrow -->
      <div class="hidden md:block text-blue-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
      <div class="block md:hidden text-blue-300 rotate-90 my-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <!-- Step 3 (Highlighted) -->
      <div class="card p-6 w-full md:w-56 flex flex-col items-center border-indigo-200 shadow-[0_16px_40px_rgba(99,102,241,0.1)] relative">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-indigo-50/50 rounded-[19px] pointer-events-none"></div>
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 flex items-center justify-center text-white mb-4 shadow-md shadow-blue-500/20 relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-9 5-9-5"/><path d="m21 8-9 5-9-5"/><path d="m3 8 9-5 9 5"/><path d="m12 13 0 9"/></svg>
        </div>
        <div class="font-bold text-slate-900 text-sm mb-1 relative z-10">Codex Proxy</div>
        <div class="text-xs text-indigo-600 font-medium relative z-10">Route & manage</div>
      </div>

      <!-- Arrow -->
      <div class="hidden md:block text-blue-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>
      <div class="block md:hidden text-blue-300 rotate-90 my-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </div>

      <!-- Step 4 -->
      <div class="card p-6 w-full md:w-56 flex flex-col items-center">
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-700 mb-4 border border-slate-200 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 14v1"/><path d="M9 19v2"/><path d="M9 3v2"/><path d="M9 9v1"/><path d="M15 14v1"/><path d="M15 19v2"/><path d="M15 3v2"/><path d="M15 9v1"/></svg>
        </div>
        <div class="font-bold text-slate-900 text-sm mb-1">Upstreams</div>
        <div class="text-xs text-slate-500">Chat / Completions</div>
      </div>

    </div>
  </div>
</section>
