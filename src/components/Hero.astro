---
---
<section class="relative pt-20 pb-12 md:pt-28 md:pb-16 px-4 overflow-hidden">
  <div class="hero-orb"></div>
  
  <div class="max-w-[1180px] mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-[46fr_54fr] gap-12 lg:gap-8 items-center">
      
      <!-- Left Content -->
      <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100 border border-slate-200/80 text-xs font-semibold text-slate-700 mb-8 tracking-wider">
          <span class="text-yellow-500">⚡</span>
          PURE PYTHON &bull; ZERO DEPENDENCIES
        </div>

        <!-- Headline -->
        <h1 class="text-[42px] md:text-[56px] lg:text-[68px] leading-[1.05] font-extrabold tracking-tight text-slate-900 mb-6">
          Use Codex with<br />
          <span class="gradient-text pb-2">any model backend.</span>
        </h1>

        <!-- Subheadline -->
        <p class="max-w-2xl lg:max-w-md text-[16px] md:text-[18px] text-slate-500 leading-relaxed mb-10">
          Route Codex IDE / CLI traffic to Ollama, NVIDIA Build, OpenRouter, vLLM, SGLang, LM Studio, DeepSeek, or any OpenAI-compatible API through one lightweight proxy.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center gap-4 mb-12 w-full sm:w-auto">
          <a href="#quick-start" class="btn-primary w-full sm:w-auto px-8 py-3.5 font-medium text-center">
            Get Started &rarr;
          </a>
          <a href="https://github.com/kyoo-147/codex_proxy_for_all_models" target="_blank" rel="noopener noreferrer" class="btn-secondary w-full sm:w-auto px-8 py-3.5 font-medium text-center">
            View GitHub
          </a>
        </div>

        <!-- Feature Chips -->
        <div class="flex flex-col sm:flex-row gap-3 w-full">
          <div class="flex items-center gap-2 px-3 py-2.5 rounded-[12px] bg-slate-50/60 border border-slate-200/60 flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            <div class="text-[12px] font-medium text-slate-700">Near-zero overhead</div>
          </div>
          
          <div class="flex items-center gap-2 px-3 py-2.5 rounded-[12px] bg-slate-50/60 border border-slate-200/60 flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            <div class="text-[12px] font-medium text-slate-700">Native Responses API</div>
          </div>
          
          <div class="flex items-center gap-2 px-3 py-2.5 rounded-[12px] bg-slate-50/60 border border-slate-200/60 flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <div class="text-[12px] font-medium text-slate-700">Cross-platform</div>
          </div>
        </div>
      </div>

      <!-- Right Content / Terminal -->
      <div class="lg:pl-8">
        <div class="terminal is-running">
          <!-- Top Bar -->
          <div class="flex items-center px-4 py-3 bg-[#0B1526] border-b border-white/5">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-rose-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-amber-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-emerald-500/80"></div>
            </div>
            <div class="mx-auto text-xs font-medium text-slate-400 font-mono tracking-wide flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              codex-proxy
            </div>
          </div>
          <!-- Content -->
          <div class="p-6 font-mono text-[13px] leading-relaxed text-slate-300">
            <div class="terminal-output" data-terminal-loop style="min-height: 380px;"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

