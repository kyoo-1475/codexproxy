---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import TerminalDemo from '../components/TerminalDemo.astro';
import ProviderGrid from '../components/ProviderGrid.astro';
import PoolModeAndQuickStart from '../components/PoolModeAndQuickStart.astro';
import ValueStrip from '../components/ValueStrip.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Codex Proxy - One IDE. Infinite Models.">
  <div class="bg-grid absolute inset-0 fixed z-[-2] pointer-events-none opacity-60"></div>
  <Navbar />
  <main class="relative pt-8">
    <Hero />
    <TerminalDemo />
    <ProviderGrid />
    <PoolModeAndQuickStart />
    <ValueStrip />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
