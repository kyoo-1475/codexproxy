---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Codex Proxy for All Models">
  <div class="relative w-full overflow-hidden selection:bg-slate-200">
    <!-- Header -->
    <header class="border-b border-slate-200 bg-white/70 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-2 font-semibold text-sm tracking-tight text-slate-900">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-network text-slate-700"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/></svg>
          Codex Proxy
        </div>
        <nav class="flex items-center gap-6 text-sm font-medium text-slate-600">
          <a href="#providers" class="hover:text-slate-900 transition-colors">Providers</a>
          <a href="#pool-mode" class="hover:text-slate-900 transition-colors">Pool Mode</a>
          <a href="#quick-start" class="hover:text-slate-900 transition-colors">Quick Start</a>
          <a href="https://github.com/kyoo-147/codex_proxy_for_all_models" target="_blank" class="flex items-center gap-2 px-3 py-1.5 bg-slate-900 text-white rounded-md hover:bg-slate-800 transition-colors">
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <!-- Hero Section -->
    <section class="pt-24 pb-16 px-6 max-w-7xl mx-auto">
      <div class="flex flex-col items-center text-center space-y-6 max-w-3xl mx-auto mb-16">
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-slate-900 leading-tight">
          One IDE. <br/><span class="text-slate-500">Infinite Models.</span>
        </h1>
        <p class="text-lg text-slate-600 max-w-xl">
          The lightweight bridge between your Codex IDE and any OpenAI-compatible backend. Zero dependencies, pure Python.
        </p>
        <div class="flex gap-4 pt-4">
          <a href="#quick-start" class="px-5 py-2.5 bg-slate-900 text-white text-sm font-medium rounded-lg shadow-sm hover:bg-slate-800 transition-colors">
            Get Started
          </a>
          <a href="https://github.com/kyoo-147/codex_proxy_for_all_models" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 text-sm font-medium rounded-lg shadow-sm hover:bg-slate-50 transition-colors">
            View Source
          </a>
        </div>
      </div>

      <!-- Hero Bento Mockup -->
      <div class="grid grid-cols-2 md:grid-cols-12 gap-3 md:gap-4 auto-rows-auto md:auto-rows-[120px]">
        <!-- Left top card -->
        <div class="flex flex-col col-span-2 md:col-span-3 row-span-1 bg-white border border-slate-200 rounded-2xl p-4 md:p-6 justify-center shadow-sm order-1 md:order-1">
          <div class="flex items-center gap-3">
            <div class="h-8 w-8 rounded-md bg-green-50 flex items-center justify-center border border-green-100 shrink-0">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div>
              <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Latency</p>
              <p class="text-sm font-semibold text-slate-900">Near-zero overhead</p>
            </div>
          </div>
        </div>

        <!-- Right top card -->
        <div class="flex flex-col col-span-2 md:col-span-3 row-span-1 bg-white border border-slate-200 rounded-2xl p-4 md:p-6 justify-center shadow-sm order-2 md:order-3">
           <div class="flex items-center gap-3">
            <div class="h-8 w-8 rounded-md bg-blue-50 flex items-center justify-center border border-blue-100 shrink-0">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Responses API</p>
              <p class="text-sm font-semibold text-slate-900">Native Translation</p>
            </div>
          </div>
        </div>

        <!-- Terminal (Center) - full width on mobile -->
        <div class="col-span-2 md:col-span-6 row-span-3 bg-[#0a0a0a] rounded-2xl p-1 shadow-xl ring-1 ring-slate-900/5 relative overflow-hidden flex flex-col order-3 md:order-2">
          <div class="h-10 border-b border-white/10 flex items-center px-4 gap-2">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            <p class="text-xs text-slate-500 font-mono ml-4">codex-proxy</p>
          </div>
          <div class="p-4 md:p-6 font-mono text-xs md:text-sm leading-relaxed text-slate-300 flex-1 overflow-auto">
            <p><span class="text-emerald-400">➜</span> <span class="text-blue-400">~</span> export CODEX_PROXY_UPSTREAM_BASE_URL="http://127.0.0.1:11434/v1"</p>
            <p><span class="text-emerald-400">➜</span> <span class="text-blue-400">~</span> export CODEX_PROXY_UPSTREAM_MODEL="qwen2.5-coder:7b"</p>
            <p><span class="text-emerald-400">➜</span> <span class="text-blue-400">~</span> python -m codex_proxy_for_all_models</p>
            <p class="text-slate-400 mt-2">INFO: Starting Codex Proxy...</p>
            <p class="text-slate-400">INFO: Mode: single_upstream</p>
            <p class="text-slate-400">INFO: Listening on http://127.0.0.1:8787</p>
            <p class="text-slate-400 mt-4">INFO: 127.0.0.1 - "GET /models HTTP/1.1" 200 OK</p>
            <p class="text-slate-400">INFO: 127.0.0.1 - "POST /responses HTTP/1.1" 200 OK</p>
          </div>
        </div>

        <!-- Left bottom card -->
        <div class="flex flex-col col-span-1 md:col-span-3 row-span-2 bg-white border border-slate-200 rounded-2xl p-4 md:p-6 shadow-sm justify-between order-4 md:order-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-1">Local & Remote</h3>
            <p class="text-xs md:text-sm text-slate-500">Run local Ollama models or remote APIs effortlessly.</p>
          </div>
          <div class="grid grid-cols-2 gap-2 mt-3 md:mt-4">
             <div class="bg-slate-50 border border-slate-100 rounded-lg p-2 text-center text-xs font-medium text-slate-600">vLLM</div>
             <div class="bg-slate-50 border border-slate-100 rounded-lg p-2 text-center text-xs font-medium text-slate-600">SGLang</div>
             <div class="bg-slate-50 border border-slate-100 rounded-lg p-2 text-center text-xs font-medium text-slate-600">LM Studio</div>
             <div class="bg-slate-50 border border-slate-100 rounded-lg p-2 text-center text-xs font-medium text-slate-600">Ollama</div>
          </div>
        </div>

        <!-- Right bottom card -->
        <div class="flex flex-col col-span-1 md:col-span-3 row-span-2 bg-white border border-slate-200 rounded-2xl p-4 md:p-6 shadow-sm justify-between order-5 md:order-5">
           <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-1">Pool Mode</h3>
            <p class="text-xs md:text-sm text-slate-500">Curated fallback profiles for daily work.</p>
          </div>
           <div class="mt-3 md:mt-4 space-y-2">
            <div class="flex items-center justify-between text-xs p-2 bg-slate-50 rounded border border-slate-100">
              <span class="font-mono text-slate-600">codex-fast</span>
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
            </div>
            <div class="flex items-center justify-between text-xs p-2 bg-slate-50 rounded border border-slate-100">
              <span class="font-mono text-slate-600">codex-balanced</span>
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
            </div>
            <div class="flex items-center justify-between text-xs p-2 bg-slate-50 rounded border border-slate-100">
              <span class="font-mono text-slate-600">codex-strong</span>
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Providers Section -->
    <section id="providers" class="py-24 bg-white border-y border-slate-200">
      <div class="max-w-7xl mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-4">Supported Providers</h2>
          <p class="text-slate-600 max-w-2xl text-lg">
            Swap upstreams without changing your daily Codex habits. Any provider exposing an OpenAI-compatible <code>chat/completions</code> endpoint is supported.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="group border border-slate-200 rounded-2xl p-6 hover:border-slate-300 transition-colors bg-[#fafafa]">
            <div class="h-12 w-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center mb-6 shadow-sm">
              <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">Local Servers</h3>
            <p class="text-sm text-slate-600">Seamless integration with Ollama, LM Studio, vLLM, and SGLang. Run heavy code models entirely locally.</p>
          </div>

          <div class="group border border-slate-200 rounded-2xl p-6 hover:border-slate-300 transition-colors bg-[#fafafa]">
            <div class="h-12 w-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center mb-6 shadow-sm">
              <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">NVIDIA Build</h3>
            <p class="text-sm text-slate-600">Access blazing fast endpoints like <code>z-ai/glm-5.2</code> and <code>qwen/qwen3-*</code> via integrate.api.nvidia.com.</p>
          </div>

          <div class="group border border-slate-200 rounded-2xl p-6 hover:border-slate-300 transition-colors bg-[#fafafa]">
            <div class="h-12 w-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center mb-6 shadow-sm">
              <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">OpenRouter & Cloud</h3>
            <p class="text-sm text-slate-600">Route requests to DeepSeek, OpenRouter, or any provider that handles <code>chat/completions</code> APIs.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pool Mode Section -->
    <section id="pool-mode" class="py-24 bg-[#fafafa]">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-slate-700 mb-6">
            <span class="w-2 h-2 rounded-full bg-blue-500"></span> New in v0.2+
          </div>
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-4">Enterprise-grade Pool Mode</h2>
          <p class="text-lg text-slate-600 mb-8">
            Stop worrying about rate limits. Pool mode adds automatic failover, multi-key rotation, and request cooldowns. Codex sees only three curated models, while the proxy handles the complexity.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-slate-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <div>
                <span class="font-medium text-slate-900 block">Automatic Failover</span>
                <span class="text-sm text-slate-500">Seamlessly falls back to secondary models if primary fails.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-slate-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <div>
                <span class="font-medium text-slate-900 block">Multi-key Rotation</span>
                <span class="text-sm text-slate-500">Distribute load across multiple API keys automatically.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-slate-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <div>
                <span class="font-medium text-slate-900 block">Curated Codex Profiles</span>
                <span class="text-sm text-slate-500">Maps your diverse backend models to <code>codex-fast</code>, <code>codex-balanced</code>, and <code>codex-strong</code>.</span>
              </div>
            </li>
          </ul>
        </div>
        
        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden text-sm">
          <div class="bg-slate-50 px-4 py-3 border-b border-slate-200 flex items-center justify-between">
            <span class="font-mono text-slate-600 text-xs">pool-config.toml</span>
          </div>
          <div class="p-6 bg-[#0a0a0a] text-slate-300 font-mono overflow-x-auto">
<pre><code><span class="text-slate-500"># Configure logical profiles</span>
mode = <span class="text-green-400">"pool"</span>

[profiles.<span class="text-blue-400">"codex-balanced"</span>]
visible_slug = <span class="text-green-400">"codex-balanced"</span>
display_name = <span class="text-green-400">"Codex Balanced"</span>
pool_order = [<span class="text-green-400">"cheap_free"</span>, <span class="text-green-400">"coding_fast"</span>]

<span class="text-slate-500"># Proxy handles failover transparently</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Start Section -->
    <section id="quick-start" class="py-24 bg-white border-t border-slate-200">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-4">Quick Start</h2>
          <p class="text-lg text-slate-600">Get up and running with a single process.</p>
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden mb-8">
          <div class="border-b border-slate-200 px-6 py-4 bg-slate-50">
            <h3 class="font-semibold text-slate-900">1. Clone & Set Upstream</h3>
          </div>
          <div class="p-6 bg-[#0a0a0a] text-slate-300 font-mono text-sm overflow-x-auto">
<pre><code><span class="text-slate-500"># 1. Clone</span>
git clone https://github.com/kyoo-147/codex_proxy_for_all_models.git
cd codex_proxy_for_all_models

<span class="text-slate-500"># 2. Set upstream (Example: Ollama)</span>
export CODEX_PROXY_UPSTREAM_BASE_URL=<span class="text-green-400">"http://127.0.0.1:11434/v1"</span>
export CODEX_PROXY_UPSTREAM_MODEL=<span class="text-green-400">"qwen3:8b"</span>
export CODEX_PROXY_PROVIDER_LABEL=<span class="text-green-400">"Ollama"</span>

<span class="text-slate-500"># 3. Run</span>
python -m codex_proxy_for_all_models</code></pre>
          </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
          <div class="border-b border-slate-200 px-6 py-4 bg-slate-50">
            <h3 class="font-semibold text-slate-900">2. Configure Codex</h3>
          </div>
          <div class="p-6 font-mono text-sm text-slate-700 overflow-x-auto">
            <p class="mb-4 text-slate-500 font-sans">Add this to <code class="bg-slate-100 px-1.5 py-0.5 rounded text-slate-800">~/.codex/config.toml</code>:</p>
<pre><code>model = "qwen3:8b"
model_provider = "local_model_proxy"

[model_providers.local_model_proxy]
name = "Local Model Proxy"
base_url = "http://127.0.0.1:8787"
wire_api = "responses"
env_key = "DUMMY_API_KEY"</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-slate-200 bg-[#fafafa] py-12">
      <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 font-semibold text-slate-900">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-network text-slate-700"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/></svg>
          Codex Proxy
        </div>
        <p class="text-sm text-slate-500">
          Open Source under the MIT License.
        </p>
        <div class="flex items-center gap-4">
          <a href="https://github.com/kyoo-147/codex_proxy_for_all_models" class="text-sm text-slate-500 hover:text-slate-900 transition-colors">GitHub Repository</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>
